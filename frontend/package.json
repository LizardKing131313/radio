{
  "name": "radio-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "npm run typecheck && npm run format:check && npm run lint && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:css": "stylelint \"apps/**/*.css\" \"packages/**/*.css\" --max-warnings 0",
    "lint:ts": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "hls.js": "^1.6.7",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
