# Managed by Ansible. Russian edge nginx for the radio origin.

proxy_cache_path /var/cache/nginx/radio-hls
levels=1:2
keys_zone=radio_hls:20m
max_size={{ radio_edge_hls_cache_size }}
inactive=20m
use_temp_path=off;

server {
listen 80;
listen [::]:80;
server_name {{ radio_edge_effective_domain }};

location ^~ /.well-known/acme-challenge/ {
root /var/lib/radio-edge/acme;
default_type text/plain;
}

location / {
return 301 https://$host$request_uri;
}
}

server {
listen 443 ssl http2;
listen [::]:443 ssl http2;
server_name {{ radio_edge_effective_domain }};

ssl_certificate /etc/letsencrypt/live/{{ radio_edge_effective_domain }}/fullchain.pem;
ssl_certificate_key /etc/letsencrypt/live/{{ radio_edge_effective_domain }}/privkey.pem;
ssl_trusted_certificate /etc/letsencrypt/live/{{ radio_edge_effective_domain }}/chain.pem;
ssl_protocols TLSv1.2 TLSv1.3;
ssl_session_cache shared:radio_edge_ssl:10m;
ssl_session_timeout 1d;
ssl_session_tickets off;

client_max_body_size 1m;
keepalive_timeout 65s;
server_tokens off;

add_header Strict-Transport-Security "max-age=31536000" always;
add_header X-Content-Type-Options "nosniff" always;
add_header X-Frame-Options "DENY" always;
add_header Referrer-Policy "no-referrer" always;
add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

proxy_http_version 1.1;
proxy_ssl_server_name on;
proxy_ssl_name {{ radio_edge_effective_origin_host }};
proxy_ssl_verify on;
proxy_ssl_verify_depth 3;
proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;

proxy_set_header Host {{ radio_edge_effective_origin_host }};
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Host $host;
proxy_set_header X-Forwarded-Proto https;
proxy_set_header X-Forwarded-Port 443;
proxy_set_header Connection "";

proxy_connect_timeout 10s;
proxy_send_timeout 300s;
proxy_read_timeout 300s;
proxy_request_buffering off;
proxy_buffering off;
proxy_max_temp_file_size 0;

location ^~ /.well-known/acme-challenge/ {
root /var/lib/radio-edge/acme;
default_type text/plain;
}

location ~* ^/hls/.*\.m3u8$ {
access_log off;
proxy_cache off;
proxy_no_cache 1;
proxy_pass {{ radio_edge_effective_origin_url }};
}

location ~* ^/hls/.*\.(ts|m4s|mp4)$ {
access_log off;
proxy_buffering on;
proxy_cache radio_hls;
proxy_cache_lock on;
proxy_cache_valid 200 5m;
proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
proxy_pass {{ radio_edge_effective_origin_url }};
}

location ^~ /hls/ {
access_log off;
proxy_cache off;
proxy_pass {{ radio_edge_effective_origin_url }};
}

location / {
proxy_cache off;
proxy_pass {{ radio_edge_effective_origin_url }};
}
}
